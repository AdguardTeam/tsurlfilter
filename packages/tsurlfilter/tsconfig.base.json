{
  "compilerOptions": {
    "moduleResolution": "node",
    "target": "es5",
    "module":"es2015",
    "lib": ["esnext", "dom"],
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "jsonparse": ["./types/jsonparse.d.ts"],
    },
    "typeRoots": [
      "./types",
      "node_modules/@types",
      "../../node_modules/@types"
    ]
  }
}
