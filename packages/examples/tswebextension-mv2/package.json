{
    "name": "tswebextension-mv2",
    "version": "0.0.1",
    "description": "Sample manifest v2 extension with tswebextension",
    "author": "Adguard Software Ltd.",
    "license": "GPL-3.0",
    "type": "module",
    "scripts": {
        "build": "pnpm build:chrome",
        "build:chrome": "tsx ./scripts/build/index.ts",
        "build:ff": "BROWSER=firefox tsx ./scripts/build/index.ts",
        "run:ff": "tsx ./scripts/launchFirefoxExtension.ts",
        "test": "tsx ./scripts/browser-test/index.ts",
        "lint": "eslint --cache --ignore-path .gitignore --ignore-pattern 'web-ext.d.ts' . && tsc --noEmit",
        "tswebextension": "tswebextension",
        "clean": "rimraf build"
    },
    "dependencies": {
        "@adguard/tswebextension": "workspace:^",
        "bowser": "catalog:",
        "formik": "^2.2.9",
        "react": "catalog:",
        "react-dom": "catalog:",
        "webextension-polyfill": "^0.12.0"
    },
    "devDependencies": {
        "@adguard/tsurlfilter": "workspace:^",
        "@swc-node/register": "^1.6.6",
        "@swc/core": "^1.3.76",
        "@types/chrome": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "@types/webextension-polyfill": "^0.12.0",
        "@typescript-eslint/eslint-plugin": "^7.5.0",
        "@typescript-eslint/parser": "^7.5.0",
        "axios": "catalog:",
        "chalk": "catalog:",
        "clean-webpack-plugin": "catalog:",
        "copy-webpack-plugin": "catalog:",
        "css-loader": "catalog:",
        "eslint": "^8.56.0",
        "eslint-config-airbnb-typescript": "^18.0.0",
        "eslint-plugin-import": "^2.25.4",
        "html-webpack-plugin": "catalog:",
        "jsdom": "^18.1.1",
        "playwright": "catalog:",
        "rimraf": "^6.0.1",
        "style-loader": "catalog:",
        "swc-loader": "catalog:",
        "tsx": "^4.19.2",
        "typescript": "^5.4.4",
        "web-ext": "^6.6.0",
        "webpack": "catalog:"
    }
}
