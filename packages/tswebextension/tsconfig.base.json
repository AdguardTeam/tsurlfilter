{
    "compilerOptions": {
        "moduleResolution": "bundler",
        "target": "es2022",
        "module": "es2022",
        "lib": ["esnext", "dom"],
        "strict": true,
        "allowJs": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "typeRoots": [
            "./types",
            "node_modules/@types",
            "node_modules/chrome-types",
            "node_modules", // FIXME: this helps to find vitest/globals, or remove lines above
        ],
        "types": ["vitest/globals"],
    }
}
